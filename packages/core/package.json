{
  "name": "@tainakanchu/itunes-playlist-builder-core",
  "version": "0.2.0",
  "type": "module",
  "files": [
    "dist",
    "rules.schema.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./rules.schema.json": "./rules.schema.json"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "generate:schema": "tsx scripts/generateSchema.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "plist": "^3.1.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/plist": "^3.0.5",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "zod-to-json-schema": "^3.25.1"
  }
}
